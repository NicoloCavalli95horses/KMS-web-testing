			"text":"# AUT's server",
			"styleAttributes":{"textAlign":"center","shape":"pill"},
			"x":-1540,
			"y":-1000,
			"width":300,
			"height":160
		},
		{
			"id":"51b35d5461ee02e1",
			"type":"text",
			"text":"# AUT (web client)",
			"styleAttributes":{"textAlign":"center","shape":"pill"},
			"x":-1930,
